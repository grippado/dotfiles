{
  "name": "notes-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server local (stdio) para o vault Obsidian ~/.notes — busca híbrida (full-text + semântica), leitura com backlinks e escrita no inbox.",
  "bin": {
    "notes-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "reindex": "node dist/index.js --reindex"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@orama/orama": "^3.1.0",
    "@xenova/transformers": "^2.17.2",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "onnxruntime-node", "protobufjs"]
  }
}
