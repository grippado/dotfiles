#!/usr/bin/env bash
# mutirao — orquestrador de tasks em paralelo via tmux + git worktrees.
#
# Lê uma `pauta` (markdown com bloco ```json embutido), agrupa as `mãos` em
# `levas` e executa cada leva em paralelo (uma mão por git worktree, um pane
# tmux por mão). Entre levas, pausa e pede aprovação humana. Cada mão roda
# `claude -p` headless por padrão; com --simulate, roda uma mão dummy inofensiva
# (cria arquivo + commit) pra exercitar a orquestração sem IA nem tokens.
#
# Uso:
#   mutirao run <pauta.md> [--simulate] [--yes] [--only-afk]
#   mutirao status [<run_id>]
#   mutirao clean  [<run_id>|--all]
#
# Convenções:
#   - Runtime efêmero: ~/.mutirao/runs/<run_id>/  (worktrees, logs, .exit, .sh)
#   - Sessão tmux:     mutirao-<run_id>  (detached; `tmux attach` pra observar)
#   - A pauta em ~/.notes é a fonte da verdade; o runtime aqui é descartável.

set -euo pipefail

MUTIRAO_HOME="${MUTIRAO_HOME:-$HOME/.mutirao}"
RUNS_DIR="$MUTIRAO_HOME/runs"
NOTES_VAULT="${NOTES_VAULT:-$HOME/.notes}"
# caminho absoluto deste script (pro tmux reinvocar `mutirao _control` dentro do pane)
SELF="$(command -v "$0" 2>/dev/null || echo "$0")"

# ── helpers ────────────────────────────────────────────────────────────────
err()  { printf '\033[31m✗ %s\033[0m\n' "$*" >&2; }
info() { printf '\033[36m▸ %s\033[0m\n' "$*"; }
ok()   { printf '\033[32m✓ %s\033[0m\n' "$*"; }
die()  { err "$*"; exit 1; }

need() { command -v "$1" >/dev/null 2>&1 || die "dependência ausente: $1"; }

# Extrai o primeiro bloco ```json ... ``` de um arquivo markdown.
extract_json() {
  awk '/^```json/{f=1;next} /^```/{if(f)exit} f' "$1"
}

# ── run (dispatcher: modo visual com auto-attach, ou foreground com --no-attach) ─
cmd_run() {
  need jq; need tmux; need git

  local pauta="" simulate=0 assume_yes=0 only_afk=0 force_branches=0 max_parallel=4 no_attach=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --simulate) simulate=1 ;;
      --yes|-y)   assume_yes=1 ;;
      --only-afk) only_afk=1 ;;
      --force-branches) force_branches=1 ;;
      --no-attach) no_attach=1 ;;
      --max-parallel) shift; max_parallel="${1:-4}" ;;
      --max-parallel=*) max_parallel="${1#*=}" ;;
      -*) die "flag desconhecida: $1" ;;
      *)  pauta="$1" ;;
    esac
    shift
  done
  [[ "$max_parallel" =~ ^[1-9][0-9]*$ ]] || die "--max-parallel deve ser inteiro > 0"
  [ -n "$pauta" ] || die "uso: mutirao run <pauta.md> [--simulate] [--yes] [--only-afk] [--force-branches] [--max-parallel N] [--no-attach]"
  [ -f "$pauta" ] || die "pauta não encontrada: $pauta"

  local json; json="$(extract_json "$pauta")"
  [ -n "$json" ] || die "nenhum bloco \`\`\`json encontrado na pauta"
  echo "$json" | jq empty 2>/dev/null || die "bloco json inválido na pauta"

  local run_name; run_name="$(echo "$json" | jq -r '.run // "mutirao"')"
  local run_id="${run_name}-$(date +%Y%m%d-%H%M%S)"
  local run_dir="$RUNS_DIR/$run_id"
  local session="mutirao-$run_id"
  mkdir -p "$run_dir"
  echo "$json" > "$run_dir/pauta.json"
  printf '%s\n' "$pauta" > "$run_dir/pauta.source"
  # config lida pelo cmd_control (que pode rodar noutro processo, dentro do pane)
  cat > "$run_dir/run.conf" <<CONF
simulate=$simulate
assume_yes=$assume_yes
only_afk=$only_afk
force_branches=$force_branches
max_parallel=$max_parallel
CONF

  _launch "$run_dir" "$no_attach" ""
}

# ── resume: retoma um run pausado, pulando as levas já concluídas ──────────────
cmd_resume() {
  need jq; need tmux; need git
  local run_id="" no_attach=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-attach) no_attach=1 ;;
      -*) die "flag desconhecida: $1" ;;
      *)  run_id="$1" ;;
    esac; shift
  done
  [ -n "$run_id" ] || die "uso: mutirao resume <run_id> [--no-attach]"
  local run_dir="$RUNS_DIR/$run_id"
  [ -f "$run_dir/pauta.json" ] || die "run não encontrado (ou sem pauta.json): $run_id"
  tmux kill-session -t "mutirao-$run_id" 2>/dev/null || true   # recriaremos a sessão
  info "retomando $run_id — levas já concluídas serão puladas"
  _launch "$run_dir" "$no_attach" "--resume"
}

# Sobe o control: foreground (--no-attach/sem TTY) ou pane de controle + attach.
# resume_flag = "" ou "--resume".
_launch() {
  local run_dir="$1" no_attach="$2" resume_flag="${3:-}"
  local run_id; run_id="$(basename "$run_dir")"
  local session="mutirao-$run_id"
  # sem TTY (tool/CI) força foreground — não dá pra attachar nem prompt interativo
  [ -t 0 ] && [ -t 1 ] || no_attach=1
  if [ "$no_attach" -eq 1 ]; then
    cmd_control "$run_dir" --foreground $resume_flag
  else
    tmux new-session -d -s "$session" -n "mutirao" "exec '$SELF' _control '$run_dir' --in-pane $resume_flag" \
      || die "falha ao criar sessão tmux $session"
    tmux set-option -t "$session" mouse on >/dev/null 2>&1 || true
    info "abrindo o mutirão no tmux ($session) — Ctrl-b d pra sair sem matar; mutirao clean $run_id pra limpar"
    sleep 1
    if [ -n "${TMUX:-}" ]; then
      info "(já dentro do tmux: trocando de sessão; prefixo + L volta pra anterior)"
      tmux switch-client -t "$session"
    else
      exec tmux attach -t "$session"
    fi
  fi
}

# ── control: o loop de levas. Roda em foreground (--foreground) OU dentro do
#    pane de controle (--in-pane). As mãos sempre splitam na janela "mutirao".
cmd_control() {
  need jq; need tmux; need git
  local run_dir="$1"; shift || true
  local in_pane=0 resume=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --in-pane) in_pane=1 ;;
      --resume)  resume=1 ;;
      --foreground) ;;
    esac; shift
  done
  [ -f "$run_dir/pauta.json" ] || die "run_dir inválido: $run_dir"

  local simulate=0 assume_yes=0 only_afk=0 force_branches=0 max_parallel=4
  # shellcheck disable=SC1090
  [ -f "$run_dir/run.conf" ] && . "$run_dir/run.conf"
  local json; json="$(cat "$run_dir/pauta.json")"
  local run_id; run_id="$(basename "$run_dir")"
  local run_name; run_name="$(echo "$json" | jq -r '.run // "mutirao"')"
  local session="mutirao-$run_id"
  local levas; levas="$(echo "$json" | jq -r '[.maos[].leva] | unique | sort | .[]')"
  [ -n "$levas" ] || die "pauta sem mãos/levas"

  # no modo visual, o próprio pane de controle fica retido ao fim (mostra o resumo
  # em vez de fechar). As mãos já usam remain-on-exit por pane.
  [ "$in_pane" -eq 1 ] && { tmux set-option -p remain-on-exit on >/dev/null 2>&1 || true; }

  info "run_id: $run_id"
  if [ "$simulate" -eq 1 ]; then info "modo: SIMULATE (mão dummy, sem claude)"
  else info "modo: claude -p headless (streaming ao vivo nos panes)"; write_stream_formatter "$run_dir"; fi

  # alvo das mãos = janela "mutirao". Em --in-pane ela já existe (pane 0 = controle);
  # em foreground criamos a sessão detached só pros panes das mãos.
  local first_pane_free=0
  if [ "$in_pane" -eq 0 ]; then
    tmux new-session -d -s "$session" -n "mutirao" 2>/dev/null || die "falha ao criar sessão tmux $session"
    first_pane_free=1
    info "sessão tmux: $session (observe com: tmux attach -t $session)"
  fi

  # bordas com título por pane (mostra qual mão roda em cada um) + nome da janela
  tmux set-option -w -t "$session:mutirao" pane-border-status top  >/dev/null 2>&1 || true
  tmux set-option -w -t "$session:mutirao" pane-border-format \
    " #{?pane_dead,✗ ,●} #{pane_title} #{?pane_dead,(exit #{pane_dead_status}),} " >/dev/null 2>&1 || true
  # NÃO renomear a janela: o resto do código a referencia por "$session:mutirao".
  [ "$in_pane" -eq 1 ] && { tmux select-pane -T "CONTROLE · $run_name (levas/aprovação aqui)" >/dev/null 2>&1 || true; }

  for leva in $levas; do
    echo; info "═══ Leva $leva ═══"
    local ids; ids="$(echo "$json" | jq -r --argjson l "$leva" '.maos[] | select(.leva==$l) | .id')"

    # skips (HITL / --only-afk) + já-concluídas (resume)
    local runnable=()
    for id in $ids; do
      if [ "$resume" -eq 1 ] && [ -f "$run_dir/$id.exit" ]; then continue; fi  # já processada num run anterior
      local a t; a="$(echo "$json" | jq -r --argjson i "$id" '.maos[]|select(.id==$i)|.autonomy // "AFK"')"
      t="$(echo "$json" | jq -r --argjson i "$id" '.maos[]|select(.id==$i)|.title')"
      if [ "$only_afk" -eq 1 ] && [ "$a" != "AFK" ]; then
        info "  mão $id [$a] PULADA (--only-afk): $t"; echo "skipped-onlyafk" > "$run_dir/$id.exit"; continue
      fi
      if [ "$a" = "HITL" ] && [ "$simulate" -eq 0 ]; then
        info "  mão $id [HITL] requer humano — não roda headless: $t"; echo "skipped-hitl" > "$run_dir/$id.exit"; continue
      fi
      runnable+=("$id")
    done

    local launched=() leva_panes=()
    if [ "${#runnable[@]}" -eq 0 ]; then
      [ "$resume" -eq 1 ] && info "  ✓ leva $leva já concluída (resume) — pulando" || info "  (nenhuma mão a lançar nesta leva)"
      continue
    fi
    [ "${#runnable[@]}" -gt "$max_parallel" ] && info "  ${#runnable[@]} mãos, cap de concorrência=$max_parallel → em batches"

    local idx=0 batch_num=0
    while [ "$idx" -lt "${#runnable[@]}" ]; do
      batch_num=$((batch_num+1))
      local batch=( "${runnable[@]:$idx:$max_parallel}" )
      idx=$((idx+max_parallel))
      local batch_launched=()

      for id in "${batch[@]}"; do
        local m; m="$(echo "$json" | jq -c --argjson i "$id" '.maos[]|select(.id==$i)')"
        local autonomy repo_key repo_path branch prompt title linear
        autonomy="$(echo "$m" | jq -r '.autonomy // "AFK"')"
        title="$(echo "$m" | jq -r '.title')"
        linear="$(echo "$m" | jq -r '.linear // "—"')"
        repo_key="$(echo "$m" | jq -r '.repo')"
        repo_path="$(echo "$json" | jq -r --arg k "$repo_key" '.repos[$k] // empty')"
        branch="$(echo "$m" | jq -r '.branch')"
        prompt="$(echo "$m" | jq -r '.prompt')"

        [ -n "$repo_path" ] || { err "  mão $id: repo '$repo_key' sem path em .repos"; echo "97" > "$run_dir/$id.exit"; continue; }
        [ -d "$repo_path/.git" ] || { err "  mão $id: '$repo_path' não é git repo"; echo "96" > "$run_dir/$id.exit"; continue; }

        # branch: em --simulate usa nome descartável (não polui o namespace real)
        local use_branch="$branch"
        [ "$simulate" -eq 1 ] && use_branch="mutirao-sim/$run_id/mao-$id"
        local wt="$run_dir/mao-$id" wt_flag="-b"
        if git -C "$repo_path" show-ref --verify --quiet "refs/heads/$use_branch"; then
          if [ "$force_branches" -eq 1 ]; then wt_flag="-B"; else
            err "  mão $id: branch '$use_branch' já existe — use --force-branches ou limpe antes"; echo "95" > "$run_dir/$id.exit"; continue
          fi
        fi
        git -C "$repo_path" worktree add -q "$wt" $wt_flag "$use_branch" 2>/dev/null \
          || { err "  mão $id: falha no worktree ($use_branch)"; echo "94" > "$run_dir/$id.exit"; continue; }
        printf '%s\t%s\n' "$repo_path" "$use_branch" > "$run_dir/$id.branch"

        printf '%s' "$prompt" > "$run_dir/$id.prompt"
        build_mao_script "$run_dir" "$id" "$wt" "$simulate"
        local pane_cmd="bash '$run_dir/$id.sh' 2>&1 | tee '$run_dir/$id.log'"

        local pid=""
        if [ "$first_pane_free" -eq 1 ]; then
          # foreground: reusa o pane 0 vazio da sessão pra 1ª mão (shell vivo → send-keys)
          pid="$(tmux list-panes -t "$session:mutirao" -F '#{pane_id}' | head -1)"
          tmux send-keys -t "$pid" "$pane_cmd" Enter
          first_pane_free=0
        else
          # demais (e todas no modo visual): split com o comando direto; remain-on-exit
          # mantém o pane visível após terminar (matamos no fim da leva, no modo visual)
          pid="$(tmux split-window -P -F '#{pane_id}' -t "$session:mutirao" "$pane_cmd" 2>/dev/null)"
          tmux set-option -p -t "$pid" remain-on-exit on >/dev/null 2>&1 || true
          tmux select-layout -t "$session:mutirao" tiled >/dev/null 2>&1 || true
        fi
        local label="mão $id · L$leva · $autonomy · $linear · $title"
        printf '%s' "$label" > "$run_dir/$id.label"   # o stream-fmt.sh lê pra compor o título com métricas
        tmux select-pane -t "$pid" -T "$label" >/dev/null 2>&1 || true
        batch_launched+=("$id"); launched+=("$id"); leva_panes+=("$pid")
        ok "  mão $id [$autonomy] lançada → $use_branch  ($title)"
      done

      # espera o batch fechar antes do próximo (cap de concorrência real)
      if [ "${#batch_launched[@]}" -gt 0 ]; then
        info "  aguardando ${#batch_launched[@]} mão(s) do batch $batch_num fecharem..."
        local pending=1
        while [ "$pending" -ne 0 ]; do
          pending=0
          for id in "${batch_launched[@]}"; do [ -f "$run_dir/$id.exit" ] || pending=$((pending+1)); done
          [ "$pending" -ne 0 ] && sleep 2
        done
      fi
    done

    # falha de setup (mão runnable que não pôde ser lançada: colisão, repo inválido)
    local setup_fail=$(( ${#runnable[@]} - ${#launched[@]} ))
    if [ "$setup_fail" -gt 0 ]; then
      err "  leva $leva: $setup_fail mão(s) não lançada(s) por falha de setup. Parando para inspeção."
      err "  runtime em $run_dir"; _control_footer "$in_pane" "$run_id"; return 1
    fi
    [ "${#launched[@]}" -eq 0 ] && continue

    echo; info "  ── resultado da leva $leva ──"
    local leva_fail=0
    for id in "${launched[@]}"; do
      local code; code="$(cat "$run_dir/$id.exit" 2>/dev/null || echo "?")"
      if [ "$code" = "0" ]; then ok "    mão $id: OK"; else err "    mão $id: exit=$code (log: $run_dir/$id.log)"; leva_fail=$((leva_fail+1)); fi
    done
    if [ "$leva_fail" -ne 0 ]; then
      err "  leva $leva teve $leva_fail falha(s). Parando para inspeção (worktrees preservados em $run_dir)."
      _control_footer "$in_pane" "$run_id"; return 1
    fi

    # aprovação antes da próxima leva
    local is_last; is_last="$(echo "$levas" | tail -1)"
    if [ "$leva" != "$is_last" ]; then
      if [ "$assume_yes" -eq 1 ]; then info "  --yes: liberando próxima leva automaticamente"
      else
        info "  (pra pausar e continuar DEPOIS: prefixo + d agora pra destacar, e responda 'y' ao reattachar)"
        printf '\033[33m? Liberar a próxima leva agora? [y = sim · N = encerrar este run] \033[0m'; read -r ans || ans=""
        case "$ans" in
          y|Y|s|S) ;;
          *) echo; info "ENCERRADO na leva $leva. Levas até aqui concluídas; as próximas NÃO foram lançadas."
             info "Worktrees e branches preservados em $run_dir."
             info "Pra retomar da próxima leva quando quiser:  mutirao resume $run_id"
             _control_footer "$in_pane" "$run_id"; return 0 ;;
        esac
      fi
      # modo visual: limpa os panes da leva concluída pra próxima leva entrar limpa
      if [ "$in_pane" -eq 1 ]; then for p in "${leva_panes[@]}"; do tmux kill-pane -t "$p" 2>/dev/null || true; done; fi
    fi
  done

  echo
  local n_ok=0 n_skip=0 n_fail=0
  for f in "$run_dir"/*.exit; do
    [ -e "$f" ] || continue
    case "$(cat "$f")" in 0) n_ok=$((n_ok+1));; skipped-*) n_skip=$((n_skip+1));; *) n_fail=$((n_fail+1));; esac
  done
  if [ "$n_fail" -eq 0 ]; then ok "mutirão concluído: $n_ok OK, $n_skip pulada(s) ($run_id)"
  else err "mutirão concluído com $n_fail falha(s), $n_ok OK, $n_skip pulada(s) ($run_id)"; fi
  write_result_note "$run_dir" "$run_id" "$json" "$n_ok" "$n_skip" "$n_fail"
  info "worktrees em $run_dir"
  _control_footer "$in_pane" "$run_id"
}

# No modo visual, imprime o rodapé de saída. O pane fica retido (remain-on-exit),
# então não fecha sozinho — você lê o resumo e sai/limpa quando quiser.
_control_footer() {
  [ "${1:-0}" -eq 1 ] || return 0
  echo
  printf '\033[36m▸ Este pane fica aberto (não fecha sozinho).\033[0m\n'
  printf '\033[36m  • voltar pra sua sessão: prefixo + d   • limpar tudo: mutirao clean %s\033[0m\n' "$2"
}

# Grava nota de resultado no 0-inbox do vault (pending_organize → /organize adota).
# Best-effort: se não houver vault, só avisa e segue.
write_result_note() {
  local run_dir="$1" run_id="$2" json="$3" n_ok="$4" n_skip="$5" n_fail="$6"
  local inbox="$NOTES_VAULT/0-inbox"
  [ -d "$inbox" ] || { info "vault inbox não encontrado ($inbox) — nota de resultado pulada"; return 0; }

  local run_name; run_name="$(echo "$json" | jq -r '.run // "mutirao"')"
  local d t; d="$(date +%Y-%m-%d)"; t="$(date +%H:%M)"
  local out="$inbox/$(date +%Y-%m-%d-%H%M)-mutirao-result-$run_name.md"
  local status="done"; [ "$n_fail" -gt 0 ] && status="failed"

  {
    echo '---'
    echo "title: \"Resultado mutirão — $run_name\""
    echo "date: \"$d\""
    echo "time: \"$t\""
    echo "type: mutirao-run-result"
    echo "status: $status"
    echo "run_id: $run_id"
    echo "pending_organize: true"
    echo "suggested_subtype: mutirao-run-result"
    echo "tags: [mutirao, resultado, orchestration, pending-organize]"
    echo '---'
    echo
    echo "# Resultado do mutirão — $run_name"
    echo
    echo "Run \`$run_id\` — **$n_ok OK**, $n_skip pulada(s), $n_fail falha(s)."
    echo
    echo "| Mão | Repo | Branch | Autonomia | Leva | Exit | PR |"
    echo "|---|---|---|---|---|---|---|"
    echo "$json" | jq -r '.maos[] | "\(.id)\t\(.repo)\t\(.branch)\t\(.autonomy)\t\(.leva)"' \
    | while IFS=$'\t' read -r id repo branch autonomy leva; do
        local code wt pr
        code="$(cat "$run_dir/$id.exit" 2>/dev/null || echo '-')"
        wt="$run_dir/mao-$id"; pr='-'
        if command -v gh >/dev/null 2>&1 && [ -d "$wt" ]; then
          pr="$(cd "$wt" 2>/dev/null && gh pr view --json url -q .url 2>/dev/null || true)"
          [ -z "$pr" ] && pr='-'
        fi
        echo "| $id | $repo | \`$branch\` | $autonomy | $leva | $code | $pr |"
      done
    echo
    echo "> Runtime: \`$run_dir\` (worktrees preservados até \`mutirao clean $run_id\`)."
    echo "> Pauta: \`$run_dir/pauta.source\`."
  } > "$out"
  ok "nota de resultado: $out"
}

# Gera o script de uma mão. Em simulate, mão dummy inofensiva; senão, claude -p.
build_mao_script() {
  local run_dir="$1" id="$2" wt="$3" simulate="$4"
  {
    echo '#!/usr/bin/env bash'
    echo "cd '$wt' || { echo 99 > '$run_dir/$id.exit'; exit 99; }"
    if [ "$simulate" -eq 1 ]; then
      cat <<SIM
echo "[simulate] mão $id em \$(pwd)"
echo "prompt: \$(cat '$run_dir/$id.prompt')"
sleep 2
echo "resultado da mão $id" > "mao-$id-resultado.txt"
git add -A >/dev/null 2>&1
git commit -qm "simulate: mão $id

Co-Authored-By: Claude <noreply@anthropic.com>" >/dev/null 2>&1 || true
code=0
SIM
    else
      # streaming ao vivo: stream-json → raw.jsonl (registro completo) + formatador jq → pane
      cat <<REAL
claude -p "\$(cat '$run_dir/$id.prompt')" --output-format stream-json --verbose --dangerously-skip-permissions 2>"$run_dir/$id.err" \\
  | tee "$run_dir/$id.raw.jsonl" \\
  | bash "$run_dir/stream-fmt.sh" "$run_dir" "$id"
code=\${PIPESTATUS[0]}
REAL
    fi
    echo "echo \"\$code\" > '$run_dir/$id.exit'"
    echo 'exit "$code"'
  } > "$run_dir/$id.sh"
}

# Formatador do stream-json do claude → linhas legíveis ao vivo (texto do agente,
# ferramentas usadas, resultado final). Gravado uma vez por run (modo real).
write_stream_formatter() {
  cat > "$1/stream-fmt.jq" <<'JQ'
def clamp($n): tostring | gsub("\\s+";" ") | if (length>$n) then .[0:$n]+"…" else . end;
if .type=="system" and (.subtype=="init") then "[2m▸ sessão iniciada[0m\n"
elif .type=="assistant" then
  ( .message.content[]? |
      if .type=="text" and ((.text//"")|gsub("\\s+";"")|length)>0 then "[36m💭 [0m"+(.text|clamp(260))+"\n"
      elif .type=="tool_use" then "[33m🔧 "+(.name//"tool")+"[0m "+(( .input.file_path // .input.command // .input.pattern // .input.description // .input.path // "")|clamp(160))+"\n"
      else empty end )
elif .type=="result" then "\n[32m✓ FIM ("+(.subtype//"?")+(if .total_cost_usd then (", $"+((.total_cost_usd*1000|round)/1000|tostring)) else "" end)+")[0m\n"
else empty end
JQ

  # wrapper: imprime as linhas legíveis (stream-fmt.jq) E atualiza o título do pane
  # (borda) com métricas ao vivo, estilo ccstatusline: modelo · contexto · output · turnos.
  cat > "$1/stream-fmt.sh" <<'SH'
#!/usr/bin/env bash
RD="$1"; ID="$2"
FMT="$RD/stream-fmt.jq"
LABEL="$(cat "$RD/$ID.label" 2>/dev/null || echo "mão $ID")"
PANE="${TMUX_PANE:-}"
model="?"; out=0; turns=0; ctx=0
settitle(){ [ -n "$PANE" ] && tmux select-pane -t "$PANE" -T "$1" >/dev/null 2>&1 || true; }
while IFS= read -r line; do
  [ -n "$line" ] || continue
  printf '%s\n' "$line" | jq -rj --unbuffered -f "$FMT" 2>/dev/null
  # campo model vira "-" quando ausente (tab é IFS-whitespace; campo vazio colapsaria e desalinharia)
  IFS=$'\t' read -r typ m it ot ca _co < <(printf '%s' "$line" | jq -rc '[(.type//"-"),(.model//"-"),((.message.usage.input_tokens)//0),((.message.usage.output_tokens)//0),(((.message.usage.cache_read_input_tokens)//0)+((.message.usage.cache_creation_input_tokens)//0)),((.total_cost_usd)//0)]|@tsv' 2>/dev/null)
  case "$typ" in
    system)    [ -n "$m" ] && [ "$m" != "-" ] && [ "$m" != "null" ] && model="${m#claude-}" ;;
    assistant) ctx=$(( (${it:-0} + ${ca:-0}) / 1000 )); out=$(( out + ${ot:-0} )); turns=$(( turns + 1 ))
               settitle "${model} · ${ctx}k ctx · ${out} out · t${turns} │ ${LABEL}" ;;
    result)    c=$(printf '%.2f' "${_co:-0}" 2>/dev/null || echo "${_co:-0}"); settitle "✓ ${model} · ${out} out · \$${c} │ ${LABEL}" ;;
  esac
done
SH
}

# ── status ────────────────────────────────────────────────────────────────────
cmd_status() {
  local run_id="${1:-}"
  if [ -z "$run_id" ]; then
    [ -d "$RUNS_DIR" ] || { info "nenhuma run ainda"; return; }
    info "runs em $RUNS_DIR:"
    ls -1t "$RUNS_DIR" 2>/dev/null | while read -r r; do
      local n done_n; n="$(ls "$RUNS_DIR/$r"/*.prompt 2>/dev/null | wc -l | tr -d ' ')"; done_n="$(ls "$RUNS_DIR/$r"/*.exit 2>/dev/null | wc -l | tr -d ' ')"
      printf '  %-40s %s/%s mãos concluídas\n' "$r" "$done_n" "$n"
    done
    return
  fi
  local run_dir="$RUNS_DIR/$run_id"
  [ -d "$run_dir" ] || die "run não encontrada: $run_id"
  info "run $run_id"
  if [ -f "$run_dir/pauta.json" ]; then
    jq -r '.maos[] | "  mão \(.id) [\(.autonomy)] leva \(.leva) — \(.title)"' "$run_dir/pauta.json"
  fi
  echo "  ── estado ──"
  for f in "$run_dir"/*.exit; do
    [ -e "$f" ] || continue
    local id; id="$(basename "$f" .exit)"
    printf '  mão %s: exit=%s\n' "$id" "$(cat "$f")"
  done
  local sess="mutirao-$run_id"
  tmux has-session -t "$sess" 2>/dev/null && info "sessão tmux viva: tmux attach -t $sess" || info "sessão tmux encerrada"
}

# ── clean ─────────────────────────────────────────────────────────────────────
cmd_clean() {
  local target="" keep_branches=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --keep-branches) keep_branches=1 ;;
      --all) target="--all" ;;
      -*) die "flag desconhecida: $1" ;;
      *) target="$1" ;;
    esac
    shift
  done
  [ -n "$target" ] || die "uso: mutirao clean <run_id>|--all [--keep-branches]"
  local runs=()
  if [ "$target" = "--all" ]; then
    [ -d "$RUNS_DIR" ] && while read -r r; do runs+=("$r"); done < <(ls -1 "$RUNS_DIR" 2>/dev/null)
  else
    runs+=("$target")
  fi
  for run_id in "${runs[@]}"; do
    local run_dir="$RUNS_DIR/$run_id"
    [ -d "$run_dir" ] || { err "run inexistente: $run_id"; continue; }
    # remove worktrees registrados (descobre o repo via .git do worktree)
    for wt in "$run_dir"/mao-*; do
      [ -d "$wt" ] || continue
      local gitdir; gitdir="$(git -C "$wt" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
      if [ -n "$gitdir" ]; then
        local repo_root; repo_root="$(dirname "$gitdir")"
        git -C "$repo_root" worktree remove --force "$wt" 2>/dev/null || rm -rf "$wt"
      else
        rm -rf "$wt"
      fi
    done
    # deleta as branches que o run criou (registradas em *.branch); só depois dos worktrees
    if [ "$keep_branches" -eq 0 ]; then
      for bf in "$run_dir"/*.branch; do
        [ -e "$bf" ] || continue
        local rp br; IFS=$'\t' read -r rp br < "$bf"
        [ -n "$rp" ] && [ -n "$br" ] || continue
        if git -C "$rp" branch -D "$br" >/dev/null 2>&1; then echo "    branch deletada: $br"; fi
      done
    fi
    tmux kill-session -t "mutirao-$run_id" 2>/dev/null || true
    rm -rf "$run_dir"
    ok "limpo: $run_id"
  done
}

# ── dispatch ──────────────────────────────────────────────────────────────────
main() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    run)      cmd_run "$@" ;;
    resume)   cmd_resume "$@" ;;
    _control) cmd_control "$@" ;;
    status)   cmd_status "$@" ;;
    clean)    cmd_clean "$@" ;;
    ""|-h|--help)
      cat <<EOF
mutirao — orquestrador de tasks em paralelo (tmux + git worktrees)

  mutirao run <pauta.md> [--simulate] [--yes] [--only-afk] [--force-branches] [--max-parallel N] [--no-attach]
      Executa a pauta em levas. Por padrão abre um pane de controle + panes das
      mãos no tmux e te attacha (visual). --no-attach roda em foreground (sem
      attach), e é forçado quando não há TTY (scripts/CI).
      --simulate usa mão dummy (sem claude). --yes pula a aprovação entre levas.
      --only-afk ignora mãos HITL. --force-branches recria branches (-B).
      --max-parallel N limita mãos simultâneas por leva (default 4).
  mutirao resume <run_id> [--no-attach]
      Retoma um run encerrado/pausado, pulando as levas já concluídas e
      continuando da próxima leva pendente.
  mutirao status [<run_id>]            Lista runs ou detalha uma.
  mutirao clean  <run_id>|--all [--keep-branches]   Remove worktrees, branches, tmux e runtime.
EOF
      ;;
    *) die "subcomando desconhecido: $sub (veja: mutirao --help)" ;;
  esac
}
main "$@"
