// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
//
// Versionado em ~/.dotfiles/zed/settings.json e symlinkado para
// ~/.config/zed/settings.json pelo install.sh.
{
  // Extensões reinstaladas automaticamente (máquina nova).
  // Adicionar/remover slugs aqui em vez de instalar só pela UI.
  // Go já é built-in no Zed (não precisa extensão).
  // Opcionais p/ adicionar via UI: markdown-oxide (PKM/wikilinks), mermaid.
  "cli_default_open_behavior": "existing_window",
  "diff_view_style": "split",
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "dockerfile": true,
    "toml": true,
    "make": true,
    "html": true,
    "git-firefly": true,
    "log": true,
    "graphql": true,
    "prisma": true,
    "angular": true
  },
  // Detecção de linguagem para dotfiles sem extensão/shebang.
  // A chave tem que bater com o nome da linguagem no Zed: "Shell Script".
  "file_types": {
    "Shell Script": [
      ".zsh*",
      ".bash*",
      ".profile",
      ".aliases",
      ".functions",
      ".secrets",
      ".env",
      ".env.*",
      "*.zsh_*"
    ]
  },
  "git_panel": {
    "dock": "left"
  },
  "terminal": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "right"
  },
  "agent_ui_font_size": 15.0,
  "tabs": {
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_menu": true,
    "show_sign_in": true,
    "show_branch_status_icon": true,
  },
  "buffer_font_weight": 300.0,
  "buffer_font_family": "CaskaydiaMono Nerd Font Mono",
  "agent": {
    "dock": "left",
    "show_turn_stats": true,
    "message_editor_min_lines": 10,
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "restore_on_startup": "empty_tab",
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "type": "registry",
    },
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Macchiato",
  },
  "ui_font_size": 16,
  "buffer_font_size": 13.55,
  "theme": "One Dark",
}
