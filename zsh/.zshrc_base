export ZSH="${HOME}/.oh-my-zsh"
export DFL="${HOME}/.dotfiles"

# Load secrets
source $DFL/configs/secrets.sh

# Theme
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins
plugins=(
    git
    node
    npm
    yarn
    fzf
    zsh-autosuggestions
    zsh-syntax-highlighting
    docker
    docker-compose
    kubectl
    gcloud
    pip
    python
    brew
    macos
    vscode
    golang
    rust
    aws
    terraform
    helm
    minikube
    kubectx
    kube-ps1
)

# Load Oh My Zsh
source $ZSH/oh-my-zsh.sh

# Load custom configurations
source $DFL/zsh/.zsh_alias
source $DFL/zsh/.zsh_functions
source $DFL/zsh/.zsh_git
source $DFL/zsh/.zsh_gcloud
source $DFL/zsh/.zsh_aws

# Load FZF
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# PATH configurations
export PATH="/usr/local/sbin:$PATH"



# cursor-agent
export PATH="$HOME/.local/bin:$PATH"

# pnpm configuration
export PNPM_HOME="${HOME}/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# direnv configuration
eval "$(direnv hook zsh)"

# FNM configuration
eval "$(fnm env --use-on-cd --shell zsh)"

# Set default Node version
fnm use lts/latest > /dev/null 2>&1

# Enable Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# PSQL
export PATH="/opt/homebrew/Cellar/postgresql@15/15.12_1/bin:$PATH"

# GO
export GOROOT="/usr/local/go"
export GOPATH="$HOME/Documents/go"
export PATH="$GOPATH/bin:$GOROOT/bin:$PATH"


# Google Cloud SDK
source "${HOME}/.google-cloud-sdk/path.zsh.inc"
source "${HOME}/.google-cloud-sdk/completion.zsh.inc"

# JAVA HOME
export JAVA_HOME="/opt/homebrew/opt/openjdk@21"
export PATH="$JAVA_HOME/bin:$PATH"

