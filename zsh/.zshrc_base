export ZSH="${HOME}/.oh-my-zsh"
export DFL="${HOME}/.dotfiles"

# Load secrets
source $DFL/configs/secrets.sh

# Theme
ZSH_THEME="powerlevel10k/powerlevel10k"

# Plugins
plugins=(
    git
    node
    npm
    yarn
    fzf
    zsh-autosuggestions
    zsh-syntax-highlighting
    docker
    docker-compose
    kubectl
    gcloud
    pip
    python
    brew
    macos
    vscode
    golang
    rust
    aws
    terraform
    helm
    minikube
    kubectx
    kube-ps1
)

# Load Oh My Zsh
source $ZSH/oh-my-zsh.sh

# Load custom configurations
source $DFL/zsh/.zsh_alias
source $DFL/zsh/.zsh_functions
source $DFL/zsh/.zsh_git

# Load FZF
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# PATH configurations
export PATH="/usr/local/sbin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# pnpm configuration
export PNPM_HOME="${HOME}/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# direnv
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"

# FNM (Fast Node Manager)
if command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd --shell zsh)"
    fnm use default > /dev/null 2>&1
fi

# Enable Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Google Cloud SDK (conditional)
[ -f "${HOME}/.google-cloud-sdk/path.zsh.inc" ] && source "${HOME}/.google-cloud-sdk/path.zsh.inc"
[ -f "${HOME}/.google-cloud-sdk/completion.zsh.inc" ] && source "${HOME}/.google-cloud-sdk/completion.zsh.inc"

# Load machine-specific configuration (paths, org tools, etc.)
# Create ~/.zshrc_local for machine-specific overrides:
#   - PSQL, Go, Java paths
#   - Org-specific aliases and functions
#   - Machine-specific environment variables
[ -f "$HOME/.zshrc_local" ] && source "$HOME/.zshrc_local"