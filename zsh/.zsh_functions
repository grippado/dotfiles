# Brain sync - pull latest notes before opening claude
function brain-sync() {
    local notes_dir="$HOME/.notes"
    if [[ -d "$notes_dir/.git" ]]; then
        git -C "$notes_dir" fetch origin 2>/dev/null
        local behind=$(git -C "$notes_dir" rev-list HEAD..origin/main --count 2>/dev/null)
        if [[ "$behind" -gt 0 ]]; then
            echo "[brain] $behind commits behind remote, pulling..."
            git -C "$notes_dir" pull --rebase origin main 2>/dev/null && echo "[brain] synced" || echo "[brain] pull failed, continuing..."
        else
            echo "[brain] up to date"
        fi
        local ahead=$(git -C "$notes_dir" rev-list origin/main..HEAD --count 2>/dev/null)
        if [[ "$ahead" -gt 0 ]]; then
            echo "[brain] $ahead local commits not pushed"
        fi
    fi
}

# Brain push - commit and push notes
function brain-push() {
    local notes_dir="$HOME/.notes"
    local msg="${1:-brain: update}"
    if [[ -d "$notes_dir/.git" ]]; then
        cd "$notes_dir"
        if [[ -n $(git status --porcelain) ]]; then
            git add -A && git commit -m "$msg" && git push origin main && echo "[brain] pushed" || echo "[brain] push failed"
        else
            local ahead=$(git rev-list origin/main..HEAD --count 2>/dev/null)
            if [[ "$ahead" -gt 0 ]]; then
                git push origin main && echo "[brain] $ahead commits pushed" || echo "[brain] push failed"
            else
                echo "[brain] nothing to push"
            fi
        fi
        cd - > /dev/null
    fi
}

# Sync brain - add, commit, and push notes
function sync-brain {
    local commitMessage=$1
    if [ -z "$commitMessage" ]; then
        commitMessage="brain: updates"
    fi
    cd ~/.notes && git add -A && git commit -m "$commitMessage" && git push
    echo "[brain] synced"
}

# Sync workspace repos: clone missing, fast-forward existing.
# Manifest: ~/cangaco/configs/repos.txt (format: bucket/repo<TAB>url)
# Usage:
#   wsync                  # sync all
#   wsync --dry-run        # show what would happen
#   wsync --only isaac     # filter by bucket (isaac|personal|...)
#   wsync --scan           # rebuild manifest from current ~/www state
function wsync() {
  local base="$HOME/www"
  local manifest="$HOME/cangaco/configs/repos.txt"
  local dry_run=0 only="" scan=0 verbose=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --only) only="$2"; shift ;;
      --scan) scan=1 ;;
      -v|--verbose) verbose=1 ;;
      -h|--help)
        echo "wsync [--dry-run] [--only <bucket>] [--scan] [-v|--verbose]"
        echo "  buckets: isaac, personal, home (entries prefixed with ~/ in manifest)"
        echo "  --verbose: show fetch details, sha comparison, merge-detection method per repo"
        return 0
        ;;
      *) echo "wsync: unknown arg: $1" >&2; return 2 ;;
    esac
    shift
  done

  _wsv() { [ "$verbose" -eq 1 ] && echo "         $*"; }

  if [ "$scan" -eq 1 ]; then
    mkdir -p "$(dirname "$manifest")"
    : > "$manifest.tmp"
    # Preserve ~/-prefixed (home) entries from existing manifest
    [ -f "$manifest" ] && grep '^~/' "$manifest" >> "$manifest.tmp" 2>/dev/null
    for bucket_dir in "$base"/*/; do
      [ -d "$bucket_dir" ] || continue
      local bucket=$(basename "$bucket_dir")
      for repo_dir in "$bucket_dir"*/; do
        [ -d "$repo_dir/.git" ] || continue
        local repo=$(basename "$repo_dir")
        local url=$(git -C "$repo_dir" remote get-url origin 2>/dev/null) || continue
        printf "%s/%s\t%s\n" "$bucket" "$repo" "$url" >> "$manifest.tmp"
      done
    done
    sort -u "$manifest.tmp" > "$manifest" && rm "$manifest.tmp"
    echo "[wsync] manifest updated: $(wc -l < "$manifest" | tr -d ' ') repos -> $manifest"
    return 0
  fi

  if [ ! -f "$manifest" ]; then
    echo "[wsync] manifest not found at $manifest" >&2
    echo "        run: wsync --scan  (on a machine with repos already cloned)" >&2
    return 1
  fi

  local total=0 cloned=0 pulled=0 rebased=0 up_to_date=0 auto_switched=0 skipped=0 failed=0
  local -a attention=()
  local -a needfix=()
  local has_gh=0
  command -v gh >/dev/null 2>&1 && has_gh=1
  while IFS=$'\t' read -r slug url; do
    [ -z "$slug" ] && continue
    [ "${slug#\#}" != "$slug" ] && continue
    local bucket="" repo="" target="" parent=""
    case "$slug" in
      '~/'*)
        bucket="home"
        target="$HOME/${slug#'~/'}"
        parent="$HOME"
        ;;
      *)
        bucket="${slug%%/*}"
        repo="${slug#*/}"
        target="$base/$bucket/$repo"
        parent="$base/$bucket"
        ;;
    esac
    [ -n "$only" ] && [ "$bucket" != "$only" ] && continue
    total=$((total + 1))

    if [ ! -d "$target/.git" ]; then
      [ "$verbose" -eq 1 ] && echo "──── $slug ────"
      echo "[wsync] 🆕 clone     $slug"
      if [ "$dry_run" -eq 1 ]; then
        cloned=$((cloned + 1))
      else
        mkdir -p "$parent"
        if git clone "$url" "$target"; then
          cloned=$((cloned + 1))
        else
          failed=$((failed + 1))
        fi
      fi
      continue
    fi

    local branch=$(git -C "$target" symbolic-ref --short HEAD 2>/dev/null)
    local default=$(git -C "$target" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
    [ -z "$default" ] && default="main"
    local remote_url=$(git -C "$target" remote get-url origin 2>/dev/null)
    local is_github=0
    [[ "$remote_url" == *github.com* ]] && is_github=1

    if [ "$verbose" -eq 1 ]; then
      echo "──── $slug ────"
      _wsv "📂 path     $target"
      _wsv "🌿 branch   $branch  (default: $default)"
      _wsv "🔗 remote   $remote_url"
    fi

    # Fetch once up front (cheap; needed for ancestor checks and remote comparison)
    if [ "$dry_run" -eq 0 ]; then
      _wsv "🔍 fetch    origin..."
      git -C "$target" fetch --quiet origin 2>/dev/null || {
        echo "[wsync] ❌ fetch     $slug  (network?)"
        failed=$((failed + 1))
        continue
      }
    fi

    # ── Case A: on a non-default branch ───────────────────────────────────────
    if [ "$branch" != "$default" ]; then
      if [ "$dry_run" -eq 1 ]; then
        echo "[wsync] ⏭️  skip      $slug  (on $branch, default=$default — dry-run)"
        skipped=$((skipped + 1))
        continue
      fi

      local dirty=0
      [ -n "$(git -C "$target" status --porcelain 2>/dev/null)" ] && dirty=1
      _wsv "🧹 dirty    $dirty"

      # Detect if branch tip is reachable from origin/default (ff/merge commits)
      local merged=0 merge_method=""
      if git -C "$target" merge-base --is-ancestor HEAD "origin/$default" 2>/dev/null; then
        merged=1
        merge_method="ancestor of origin/$default"
      elif [ "$has_gh" -eq 1 ] && [ "$is_github" -eq 1 ]; then
        # Squash merges: branch HEAD not in main, but PR was merged
        _wsv "🔍 gh PR    checking squash-merge fallback..."
        local pr_merged=$(gh -R "$remote_url" pr list --head "$branch" --state merged --json number -L 1 2>/dev/null | grep -c '"number"')
        [ "$pr_merged" -gt 0 ] && { merged=1; merge_method="gh: PR merged (squash)"; }
      fi
      _wsv "🎯 merged   $merged${merge_method:+  ($merge_method)}"

      if [ "$merged" -eq 1 ] && [ "$dirty" -eq 0 ]; then
        echo "[wsync] 🔀 switch    $slug  ($branch merged → $default)"
        if git -C "$target" checkout --quiet "$default" && git -C "$target" pull --ff-only --quiet; then
          auto_switched=$((auto_switched + 1))
          attention+=("🔀 $slug — auto-switched $branch → $default (PR was merged)")
        else
          echo "        ❌ switch/pull failed"
          failed=$((failed + 1))
        fi
        continue
      fi

      if [ "$merged" -eq 1 ] && [ "$dirty" -eq 1 ]; then
        echo "[wsync] ⏭️  skip      $slug  (on $branch — merged but dirty)"
        attention+=("⚠️  $slug — $branch merged, but local changes prevent switch (commit/stash and re-run)")
        skipped=$((skipped + 1))
        continue
      fi

      # Not merged
      local has_upstream=0
      git -C "$target" rev-parse --verify --quiet "@{u}" >/dev/null 2>&1 && has_upstream=1
      if [ "$has_upstream" -eq 0 ]; then
        echo "[wsync] ⏭️  skip      $slug  (on $branch — never pushed)"
        attention+=("⚠️  $slug — $branch has local commits never pushed to remote")
      else
        local ahead=$(git -C "$target" rev-list --count "@{u}..HEAD" 2>/dev/null)
        echo "[wsync] ⏭️  skip      $slug  (on $branch — $ahead unpushed, not merged)"
        attention+=("⚠️  $slug — $branch ahead of upstream by $ahead commits, not yet merged into $default")
      fi
      skipped=$((skipped + 1))
      continue
    fi

    # ── Case B: on default branch — compare with origin ───────────────────────
    if [ "$dry_run" -eq 1 ]; then
      echo "[wsync] ⬇️  pull      $slug  ($branch) — dry-run"
      pulled=$((pulled + 1))
      continue
    fi

    local local_sha=$(git -C "$target" rev-parse HEAD 2>/dev/null)
    local remote_sha=$(git -C "$target" rev-parse "origin/$default" 2>/dev/null)
    _wsv "📊 local    ${local_sha:0:7}"
    _wsv "📊 remote   ${remote_sha:0:7}"

    if [ -n "$local_sha" ] && [ "$local_sha" = "$remote_sha" ]; then
      echo "[wsync] ✅ ok        $slug  (up to date)"
      up_to_date=$((up_to_date + 1))
      continue
    fi

    # Check if local is ahead of remote (unpushed commits on default branch)
    local ahead_count=$(git -C "$target" rev-list --count "origin/$default..HEAD" 2>/dev/null)
    local behind_count=$(git -C "$target" rev-list --count "HEAD..origin/$default" 2>/dev/null)
    _wsv "📊 ahead     $ahead_count    behind  $behind_count"

    if [ "$ahead_count" -gt 0 ] && [ "$behind_count" -eq 0 ]; then
      echo "[wsync] ⚠️  ahead     $slug  ($default ahead by $ahead_count unpushed)"
      attention+=("⚠️  $slug — $default ahead of origin by $ahead_count unpushed commits")
      skipped=$((skipped + 1))
      continue
    fi

    local dirty=0
    [ -n "$(git -C "$target" status --porcelain 2>/dev/null)" ] && dirty=1
    _wsv "🧹 dirty    $dirty"

    # Diverged: both local and remote moved. Typical for machine-synced repos
    # (ai-memory-sync, notes) where commits on different boxes touch different
    # files. Try to auto-rebase local commits onto origin; if it conflicts for
    # real, abort cleanly and hand the repo off to the agentic-fix prompt.
    if [ "$ahead_count" -gt 0 ] && [ "$behind_count" -gt 0 ]; then
      echo "[wsync] 🔄 rebase    $slug  (diverged: +$ahead_count local / -$behind_count remote)"
      if [ "$dirty" -eq 1 ]; then
        _wsv "📦 stash    saving local changes..."
        if ! git -C "$target" stash push -u -m "wsync auto-stash $(date +%Y%m%d-%H%M%S)" >/dev/null; then
          echo "        ❌ stash failed, skipping"
          failed=$((failed + 1))
          needfix+=("$slug	$target	$default	$branch	stash failed before rebase ($ahead_count local / $behind_count remote)")
          continue
        fi
      fi
      if git -C "$target" rebase --quiet "origin/$default" 2>/dev/null; then
        echo "        ✅ rebased $ahead_count local commit(s) onto origin/$default"
        rebased=$((rebased + 1))
      else
        git -C "$target" rebase --abort >/dev/null 2>&1
        echo "        ❌ rebase conflicted — left untouched, queued for agentic fix"
        failed=$((failed + 1))
        needfix+=("$slug	$target	$default	$branch	rebase conflict ($ahead_count local / $behind_count remote)")
      fi
      if [ "$dirty" -eq 1 ]; then
        git -C "$target" stash pop >/dev/null 2>&1 || {
          echo "        ⚠️  stash pop conflicted, check 'git stash list' in $target"
          attention+=("⚠️  $slug — stash pop conflict in $target")
        }
      fi
      continue
    fi

    echo "[wsync] ⬇️  pull      $slug  ($branch, behind $behind_count)"
    if [ "$dirty" -eq 1 ]; then
      _wsv "📦 stash    saving local changes..."
      if ! git -C "$target" stash push -u -m "wsync auto-stash $(date +%Y%m%d-%H%M%S)" >/dev/null; then
        echo "        ❌ stash failed, skipping"
        failed=$((failed + 1))
        continue
      fi
    fi

    if git -C "$target" pull --ff-only --quiet; then
      pulled=$((pulled + 1))
    else
      echo "        ❌ pull failed (non-ff or network)"
      failed=$((failed + 1))
      needfix+=("$slug	$target	$default	$branch	pull --ff-only failed (non-ff or network)")
    fi

    if [ "$dirty" -eq 1 ]; then
      git -C "$target" stash pop >/dev/null 2>&1 || {
        echo "        ⚠️  stash pop conflicted, check 'git stash list' in $target"
        attention+=("⚠️  $slug — stash pop conflict in $target")
      }
    fi
  done < "$manifest"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📊 wsync summary  ($total repos)"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  printf "  ✅ up-to-date   %3d\n" "$up_to_date"
  printf "  ⬇️  pulled       %3d\n" "$pulled"
  printf "  🔄 rebased      %3d\n" "$rebased"
  printf "  🔀 switched     %3d\n" "$auto_switched"
  printf "  🆕 cloned       %3d\n" "$cloned"
  printf "  ⏭️  skipped      %3d\n" "$skipped"
  printf "  ❌ failed       %3d\n" "$failed"

  if [ ${#attention[@]} -gt 0 ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⚠️  attention needed  (${#attention[@]})"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    for line in "${attention[@]}"; do
      echo "  $line"
    done
  fi

  # Repos wsync could not reconcile mechanically (real conflicts / network).
  # Emit a ready-to-paste prompt so an agent (Claude Code, Cursor, …) can fix
  # them with full repo context. Copy everything between the ✂ markers.
  if [ ${#needfix[@]} -gt 0 ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "🤖 agentic fix needed  (${#needfix[@]}) — paste the block below into Claude Code / Cursor"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "✂─────────────────────────────────────────────────────────────────────────✂"
    echo "wsync não conseguiu sincronizar mecanicamente os repos abaixo. Resolva cada um"
    echo "com cuidado, preservando os commits locais E os remotos (são máquinas diferentes,"
    echo "normalmente sem conflito real de conteúdo). Para cada repo:"
    echo ""
    echo "  1. cd no path, rode 'git status' e 'git log --oneline --graph --all -20'"
    echo "  2. tente 'git rebase origin/<default>'; se conflitar, resolva os arquivos"
    echo "     mantendo as duas intenções (na dúvida, pare e me pergunte)"
    echo "  3. se for repo de conteúdo gerado (ai-memory-sync, notes), favoreça a união"
    echo "     dos dois lados em vez de descartar qualquer lado"
    echo "  4. ao final, 'git status' deve estar limpo e 'git log' linear com origin"
    echo "  NÃO faça push — só deixe o working tree limpo e sincronizado localmente."
    echo ""
    echo "Repos:"
    local nf slug_ path_ default_ branch_ reason_
    for nf in "${needfix[@]}"; do
      IFS=$'\t' read -r slug_ path_ default_ branch_ reason_ <<< "$nf"
      echo "  • $slug_"
      echo "      path:    $path_"
      echo "      branch:  $branch_   (default: $default_)"
      echo "      problem: $reason_"
    done
    echo "✂─────────────────────────────────────────────────────────────────────────✂"
  fi
}
# deck2pdf <url> [output.pdf] [size]
# Converts a Reveal.js presentation served at <url> into a PDF via decktape.
# Defaults: output = <last-url-segment>.pdf, size = 1280x720.
# ex: deck2pdf http://localhost:5173/talks/automating-arco-design-system/
# ex: deck2pdf http://localhost:5173/talks/foo/ foo.pdf 1920x1080
function deck2pdf {
    if [ -z "$1" ]; then
        echo "usage: deck2pdf <url> [output.pdf] [size=1280x720]" >&2
        return 1
    fi
    local url="$1"
    local out="${2:-$(basename "${url%/}").pdf}"
    local size="${3:-1280x720}"
    npx --yes decktape reveal "$url" "$out" --size "$size" --load-pause 800
}

# agent-new <nome> [cmd] — sobe um harness de IA isolado numa janela tmux própria.
# Cria/anexa a sessão "fleet", abre uma window com o nome dado e roda o harness
# com isolamento de git worktree nativo (claude --worktree). Fora do tmux, abre
# uma sessão nova; dentro do tmux, só cria a window.
# ex: agent-new fix-login
# ex: agent-new refactor "claude --worktree --dangerously-skip-permissions"
function agent-new {
    if [ -z "$1" ]; then
        echo "usage: agent-new <nome> [comando]" >&2
        return 1
    fi
    local name="$1"
    local cmd="${2:-claude --worktree}"
    local session="fleet"

    if [ -z "$TMUX" ]; then
        tmux has-session -t "$session" 2>/dev/null \
            && tmux new-window -t "$session" -n "$name" "$cmd; zsh" \
            || tmux new-session -s "$session" -n "$name" "$cmd; zsh"
        tmux attach -t "$session"
    else
        tmux new-window -n "$name" "$cmd; zsh"
    fi
}

